SERVER_API_KEY=change-me
START_ADMIN_USERNAME=admin
START_ADMIN_PASSWORD=changeme-admin-password
TRAEFIK_DOMAIN=monitor.example.com
TRAEFIK_ACME_EMAIL=admin@example.com
TRAEFIK_DOCKER_API_VERSION=1.41

POSTGRES_DB=hardware_monitor
POSTGRES_USER=monitor_user
POSTGRES_PASSWORD=monitor_password

# Optional override. Leer lassen, damit automatisch POSTGRES_* genutzt wird.
# Wenn gesetzt, muss die URL zum POSTGRES_USER/POSTGRES_PASSWORD passen.
DATABASE_URL=

# Optional tuning
STALE_AFTER_SECONDS=180
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
LOG_DATA_ACCESS_EVENTS=false
ENABLE_DEMO_DATA=true
DEMO_USERNAME=demo
DEMO_PASSWORD=Demo!123
DEMO_CLIENT_COUNT=6
DEMO_SNAPSHOT_INTERVAL_SECONDS=60
# DB_SSLMODE=require
